# IOTA SDK .env template.
#
# Env var naming rule: UPPER_SNAKE_CASE, one underscore per dot in the
# koanf path. Example: HTTP_PORT → http.port, DB_POOL_MAXCONNS → db.pool.maxconns.
# Process environment variables override this file; defaults fill in the rest.
#
# For custom aliases (e.g. integrating with legacy deployment tooling), wire them
# via env.Provider.WithAliases(...) at bootstrap time.

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENVIRONMENT=development
# APP_ENABLETESTENDPOINTS=false
# APP_TELEGRAMBOTTOKEN=

# ─── HTTP Server ──────────────────────────────────────────────────────────────
HTTP_PORT=3200
HTTP_DOMAIN=localhost
# HTTP_ORIGIN=
# HTTP_ALLOWEDORIGINS=http://localhost:3000

# ─── HTTP Session ─────────────────────────────────────────────────────────────
HTTP_SESSION_DURATION=720h

# ─── HTTP Cookies ─────────────────────────────────────────────────────────────
HTTP_COOKIES_SID=sid
# HTTP_COOKIES_OAUTHSTATE=oauthState

# ─── HTTP Headers ─────────────────────────────────────────────────────────────
# HTTP_HEADERS_REQUESTID=X-Request-ID
# HTTP_HEADERS_REALIP=X-Real-IP

# ─── HTTP Pagination ──────────────────────────────────────────────────────────
# HTTP_PAGINATION_PAGESIZE=25
# HTTP_PAGINATION_MAXPAGESIZE=100

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iota_erp
DB_USER=postgres
DB_PASSWORD=postgres
# DB_MIGRATIONSDIR=migrations

# ─── Database Connection Pool ─────────────────────────────────────────────────
# DB_POOL_MAXCONNS=32
# DB_POOL_MINCONNS=8
# DB_POOL_MAXCONNLIFETIME=1h
# DB_POOL_MAXCONNLIFETIMEJITTER=6m
# DB_POOL_MAXCONNIDLETIME=15m
# DB_POOL_HEALTHCHECKPERIOD=1m
# DB_POOL_CONNECTTIMEOUT=10s

# ─── Telemetry ────────────────────────────────────────────────────────────────
TELEMETRY_LOGLEVEL=debug

# Loki log shipping (auto-enabled when TELEMETRY_LOKI_URL is set)
# TELEMETRY_LOKI_URL=http://localhost:3100
# TELEMETRY_LOKI_APPNAME=sdk
# TELEMETRY_LOKI_LOGPATH=./logs/app.log

# OpenTelemetry / Tempo (auto-enabled when both URL and service name are set)
# TELEMETRY_OTEL_TEMPOURL=http://localhost:4317
# TELEMETRY_OTEL_SERVICENAME=iota-sdk

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOADS_PATH=static
# UPLOADS_MAXSIZE=33554432
# UPLOADS_MAXMEMORY=33554432

# ─── Redis ────────────────────────────────────────────────────────────────────
# REDIS_URL=localhost:6379

# ─── Meilisearch (auto-enabled when MEILI_URL is set) ─────────────────────────
MEILI_URL=http://localhost:7700
# MEILI_APIKEY=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATELIMIT_ENABLED=true
RATELIMIT_GLOBALRPS=1000
RATELIMIT_STORAGE=memory
# RATELIMIT_REDISURL=redis://localhost:6379

# ─── Two-Factor Authentication ────────────────────────────────────────────────
# Two-Factor Authentication (TOTP, SMS, Email)
# TWOFACTOR_ENABLED=false
# TWOFACTOR_TOTPISSUER=IOTA ERP

# TOTP Encryption Key — REQUIRED for production.
# Generate: openssl rand -base64 32
# WARNING: If not set, TOTP secrets are stored in plaintext (development only).
# TWOFACTOR_ENCRYPTIONKEY=your-strong-random-encryption-key-here

# OTP code settings
# TWOFACTOR_OTP_CODELENGTH=6
# TWOFACTOR_OTP_TTLSECONDS=300
# TWOFACTOR_OTP_MAXATTEMPTS=3

# OTP delivery (requires SMTP / Twilio below)
# TWOFACTOR_OTP_ENABLEEMAIL=false
# TWOFACTOR_OTP_ENABLESMS=false

# ─── SMTP (for email OTP delivery) ───────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ─── Twilio (for SMS OTP delivery) ───────────────────────────────────────────
TWILIO_ACCOUNTSID=your_twilio_sid
TWILIO_AUTHTOKEN=your_twilio_token
TWILIO_PHONENUMBER=your_twilio_phone_number
# TWILIO_WEBHOOKURL=

# ─── OIDC Provider (auto-enabled when required settings are present) ──────────
OIDC_ISSUERURL=https://auth.example.com/oidc
OIDC_CRYPTOKEY=your-32-byte-base64-encoded-key-here
# OIDC_ACCESSTOKENLIFETIME=1h
# OIDC_REFRESHTOKENLIFETIME=720h
# OIDC_IDTOKENLIFETIME=1h

# ─── Google OAuth (auto-enabled when client ID + secret are set) ──────────────
GOOGLEOAUTH_CLIENTID=example-client-id
GOOGLEOAUTH_CLIENTSECRET=example-client-secret
GOOGLEOAUTH_REDIRECTURL=http://localhost:3000/auth/google/callback

# ─── Payments — Click ─────────────────────────────────────────────────────────
PAYMENTS_CLICK_URL=https://my.click.uz
PAYMENTS_CLICK_MERCHANTID=12345678
PAYMENTS_CLICK_MERCHANTUSERID=12345678
PAYMENTS_CLICK_SERVICEID=12345678
PAYMENTS_CLICK_SECRETKEY=your_secret_key

# ─── Payments — Payme ─────────────────────────────────────────────────────────
PAYMENTS_PAYME_URL=https://checkout.test.paycom.uz
PAYMENTS_PAYME_MERCHANTID=1231312131
PAYMENTS_PAYME_USER=Paycom
PAYMENTS_PAYME_SECRETKEY=your_payme_secret_key

# ─── Payments — Octo ──────────────────────────────────────────────────────────
PAYMENTS_OCTO_SHOPID=1231312
PAYMENTS_OCTO_SECRET=1231231
PAYMENTS_OCTO_SECRETHASH=1231312
PAYMENTS_OCTO_NOTIFYURL=https://notify-url.uz

# ─── Payments — Stripe ────────────────────────────────────────────────────────
PAYMENTS_STRIPE_SECRETKEY=your_stripe_secret_key
PAYMENTS_STRIPE_SIGNINGSECRET=your_stripe_signing_secret

# ─── BiChat / OpenAI ──────────────────────────────────────────────────────────
# REQUIRED for BiChat module (AI-powered chat).
BICHAT_OPENAI_APIKEY=sk-example-api-key
# BICHAT_OPENAI_MODEL=gpt-4
# BICHAT_OPENAI_BASEURL=
# BICHAT_OPENAI_RESOLVEIP=

# ─── BiChat / Langfuse (observability) ───────────────────────────────────────
# BICHAT_LANGFUSE_PUBLICKEY=
# BICHAT_LANGFUSE_SECRETKEY=
# BICHAT_LANGFUSE_BASEURL=
# BICHAT_LANGFUSE_HOST=

# ─── BiChat / Knowledge Base ─────────────────────────────────────────────────
# BICHAT_KNOWLEDGE_DIR=
# BICHAT_KNOWLEDGE_KBINDEXPATH=
# BICHAT_KNOWLEDGE_SCHEMAMETADATA=
# BICHAT_KNOWLEDGE_AUTOLOAD=false

# ─── BiChat / Applet (dev Vite server) ───────────────────────────────────────
# BICHAT_APPLET_VITEURL=http://localhost:5173
# BICHAT_APPLET_ENTRY=/src/main.tsx
# BICHAT_APPLET_CLIENT=/@vite/client

# ─── Health Endpoint ──────────────────────────────────────────────────────────
# When false (default): /health returns simple {"status": "healthy"} response
# When true: /health returns detailed health checks with database, system metrics
# HEALTH_DETAILED=false
