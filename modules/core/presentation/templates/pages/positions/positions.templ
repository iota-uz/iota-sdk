package positions

import (
	"fmt"
	"net/url"
	"strconv"

	icons "github.com/iota-uz/icons/phosphor"
	"github.com/iota-uz/iota-sdk/components/base"
	"github.com/iota-uz/iota-sdk/components/base/avatar"
	"github.com/iota-uz/iota-sdk/components/base/badge"
	"github.com/iota-uz/iota-sdk/components/base/button"
	"github.com/iota-uz/iota-sdk/components/base/dialog"
	"github.com/iota-uz/iota-sdk/components/base/input"
	sdkhelp "github.com/iota-uz/iota-sdk/components/help"
	"github.com/iota-uz/iota-sdk/modules/core/permissions"
	"github.com/iota-uz/iota-sdk/modules/core/presentation/templates/layouts"
	"github.com/iota-uz/iota-sdk/modules/core/presentation/viewmodels"
	"github.com/iota-uz/iota-sdk/pkg/composables"
)

func mkInfiniteAttrs(props *IndexPageProps) templ.Attributes {
	params := url.Values{}
	params.Set("page", strconv.Itoa(props.Page+1))
	params.Set("name", props.Search)
	params.Set("limit", strconv.Itoa(props.PerPage))

	return templ.Attributes{
		"hx-get":     "/positions?" + params.Encode(),
		"hx-trigger": "intersect once",
		"hx-swap":    "afterend",
		"hx-target":  "this",
	}
}

templ PositionRow(p *viewmodels.UserPosition, rowProps *base.TableRowProps) {
	{{ pageCtx := composables.UsePageCtx(ctx) }}
	{{
		// The detail-fetch hx-* attributes live on an inner button rather than on
		// the <tr>, so the last row's infinite-scroll pagination attributes (set
		// via mkInfiniteAttrs) are not clobbered here. Mirrors the crm/clients row.
		rowProps.Attrs["id"] = fmt.Sprintf("position-%s", p.ID)
		rowProps.Attrs["class"] = "hover:bg-surface-600"
	}}
	@base.TableRow(*rowProps) {
		@base.TableCell(base.TableCellProps{}) {
			<button
				type="button"
				x-data
				hx-get={ fmt.Sprintf("/positions/%s", p.ID) }
				hx-target="body"
				hx-swap="beforeend"
				hx-trigger="click"
				class="flex items-center gap-3 cursor-pointer text-left w-full"
			>
				@avatar.Avatar(avatar.Props{
					Initials: p.GetInitials(),
					Variant:  avatar.Round,
				})
				<span>{ p.Title }</span>
			</button>
		}
		@base.TableCell(base.TableCellProps{}) {
			<span>{ p.UserName }</span>
		}
		@base.TableCell(base.TableCellProps{}) {
			<span>{ p.DepartmentName }</span>
		}
		@base.TableCell(base.TableCellProps{}) {
			<div class="flex flex-wrap gap-2">
				if p.IsManager {
					@badge.New(badge.Props{Class: templ.Classes("px-2"), Variant: badge.VariantBlue, Size: badge.SizeNormal}) {
						{ pageCtx.T("Positions.Single.IsManager") }
					}
				}
				if p.IsPrimary {
					@badge.New(badge.Props{Class: templ.Classes("px-2"), Variant: badge.VariantPurple, Size: badge.SizeNormal}) {
						{ pageCtx.T("Positions.Single.IsPrimary") }
					}
				}
			</div>
		}
		@base.TableCell(base.TableCellProps{}) {
			if p.Status == "inactive" {
				@badge.New(badge.Props{Class: templ.Classes("px-2"), Variant: badge.VariantGray, Size: badge.SizeNormal}) {
					{ pageCtx.T("Positions.Status.Inactive") }
				}
			} else {
				@badge.New(badge.Props{Class: templ.Classes("px-2"), Variant: badge.VariantGreen, Size: badge.SizeNormal}) {
					{ pageCtx.T("Positions.Status.Active") }
				}
			}
		}
	}
}

templ PositionRows(props *IndexPageProps) {
	for ix, p := range props.Positions {
		{{
			isLastRow := ix == len(props.Positions)-1
			rowProps := &base.TableRowProps{
				Attrs: templ.Attributes{},
			}
			if isLastRow && props.HasMore {
				rowProps.Attrs = mkInfiniteAttrs(props)
			}
		}}
		@PositionRow(p, rowProps)
	}
}

templ PositionsTable(props *IndexPageProps) {
	{{ pageCtx := composables.UsePageCtx(ctx) }}
	if len(props.Positions) == 0 {
		@base.TableEmptyState(base.TableEmptyStateProps{
			Title:       pageCtx.T("Positions.List.NoPositions.Title"),
			Description: pageCtx.T("Positions.List.NoPositions._Description"),
		})
	} else {
		@base.Table(base.TableProps{
			Columns: []*base.TableColumn{
				{Label: pageCtx.T("Positions.List.Title"), Key: "title"},
				{Label: pageCtx.T("Positions.List.User"), Key: "user"},
				{Label: pageCtx.T("Positions.List.Department"), Key: "department"},
				{Label: pageCtx.T("Positions.List.Role"), Key: "role"},
				{Label: pageCtx.T("Positions.List.Status"), Key: "status"},
			},
		}) {
			<tbody id="positions-table-body">
				@PositionRows(props)
			</tbody>
		}
	}
}

templ PositionsContent(props *IndexPageProps) {
	{{ pageCtx := composables.UsePageCtx(ctx) }}
		<div class="m-6">
			<div class="flex justify-between md:justify-start">
				<div class="flex items-center gap-2">
					<h1 class="text-2xl font-medium">
						{ pageCtx.T("NavigationLinks.Positions") }
					</h1>
					@sdkhelp.Link(sdkhelp.LinkProps{Path: "modules/core-administration.md"})
				</div>
				<div class="flex md:hidden gap-2">
				if composables.CanUser(ctx, permissions.PositionCreate) == nil {
					@button.Primary(button.Props{
						Size: button.SizeNormal,
						Icon: icons.PlusCircle(icons.Props{Size: "18"}),
						Attrs: templ.Attributes{
							"type":   "button",
							"x-data": "",
							"@click": "$dispatch('new-position')",
						},
					})
				}
			</div>
		</div>
		<div class="mt-5 bg-surface-600 border border-primary rounded-lg">
			<form
				class="p-4 flex items-center gap-3"
				hx-get="/positions"
				hx-trigger="keyup changed delay:500ms from:(form input), change changed from:(form select)"
				hx-target="table"
				hx-swap="outerHTML"
			>
				<input type="hidden" name="page" value="1"/>
				<div class="flex-1">
					@input.Text(&input.Props{
						AddonLeft: &input.Addon{
							Component: icons.MagnifyingGlass(icons.Props{Size: "20"}),
						},
						Placeholder: pageCtx.T("Search"),
						Attrs: templ.Attributes{
							"name":  "name",
							"value": props.Search,
						},
					})
				</div>
				<div class="hidden md:flex gap-3">
					if composables.CanUser(ctx, permissions.PositionCreate) == nil {
						@button.Primary(button.Props{
							Size: button.SizeNormal,
							Icon: icons.PlusCircle(icons.Props{Size: "18"}),
							Attrs: templ.Attributes{
								"type":   "button",
								"x-data": "",
								"@click": "$dispatch('new-position')",
							},
						}) {
							{ pageCtx.T("Positions.List.New") }
						}
					}
				</div>
			</form>
			@PositionsTable(props)
		</div>
	</div>
}

templ NewPositionDrawer() {
	{{ pageCtx := composables.UsePageCtx(ctx) }}
	@dialog.Drawer(dialog.DrawerProps{
		Direction: dialog.RTL,
		Action:    "new-position",
		Classes:   templ.Classes("flex items-stretch"),
		ID:        "new-position-drawer",
	}) {
		<div class="bg-white w-full md:w-[450px] ml-auto">
			<div class="flex flex-col h-full">
				<form method="dialog">
					<div class="flex justify-between px-4 py-3 border-b border-primary">
						<h3 class="text-lg font-medium">
							{ pageCtx.T("Positions.Meta.New.Title") }
						</h3>
						<div>
							<button class="cursor-pointer">
								@icons.XCircle(icons.Props{Size: "20"})
							</button>
						</div>
					</div>
				</form>
				<div class="flex-1 min-h-0" hx-get="/positions/new" hx-trigger="load" hx-swap="innerHTML">
					<div class="flex justify-center items-center h-full">
						<div class="animate-spin rounded-full h-8 w-8 border-b-2 border-gray-900"></div>
					</div>
				</div>
			</div>
		</div>
	}
}

templ EditPositionDrawer(props *EditFormProps) {
	{{ pageCtx := composables.UsePageCtx(ctx) }}
	@dialog.Drawer(dialog.DrawerProps{
		Direction: dialog.RTL,
		Action:    "edit-position",
		Open:      true,
		Classes:   templ.Classes("flex items-stretch"),
		ID:        "edit-position-drawer",
		Attrs: templ.Attributes{
			"@closing": "window.history.pushState({}, '', '/positions')",
			"@closed":  "document.getElementById('edit-position-drawer').remove()",
		},
	}) {
		<div class="bg-white w-full md:w-[450px] ml-auto">
			<div class="flex flex-col h-full">
				<form method="dialog">
					<div class="flex justify-between px-4 py-3 border-b border-primary">
						<h3 class="text-lg font-medium">
							{ pageCtx.T("Positions.Meta.Edit.Title") }
						</h3>
						<div>
							<button class="cursor-pointer">
								@icons.XCircle(icons.Props{Size: "20"})
							</button>
						</div>
					</div>
				</form>
				<div class="flex-1 min-h-0">
					@EditForm(props)
				</div>
			</div>
		</div>
	}
}

templ Index(props *IndexPageProps) {
	{{ pageCtx := composables.UsePageCtx(ctx) }}
	@layouts.Authenticated(layouts.AuthenticatedProps{
		BaseProps: layouts.BaseProps{Title: pageCtx.T("Positions.Meta.List.Title")},
	}) {
		@PositionsContent(props)
		@NewPositionDrawer()
	}
}
